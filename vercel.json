{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/:route*",
      "destination": "/api/index?__route=:route*"
    }
  ],
  "functions": {
    "api/index.mjs": {
      "includeFiles": "data/**",
      "maxDuration": 60
    }
  }
}
